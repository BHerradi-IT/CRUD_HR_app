pipeline {
    agent any
    
    environment {
        // إعدادات Django
        DJANGO_SETTINGS_MODULE = 'config.settings.production'
        SECRET_KEY = 'django-insecure-jenkins-build-key-2024'
        DEBUG = 'False'
        ALLOWED_HOSTS = 'localhost,127.0.0.1'
        
        // إعدادات قاعدة البيانات (PostgreSQL من compose.yaml)
        DB_NAME = 'hr_app_db'
        DB_USER = 'postgres'
        DB_PASSWORD = 'postgres'
        DB_HOST = 'localhost'
        DB_PORT = '5432'
        
        // إعدادات Python
        PYTHONUNBUFFERED = '1'
    }
    
    stages {
        stage('📥 سحب الكود من GitHub') {
            steps {
                git branch: 'main', 
                    url: 'https://github.com/BHerradi-IT/CRUD_HR_app.git'
                echo '✅ تم سحب الكود من المستودع'
            }
        }
        
        stage('🐍 تجهيز Python والبيئة الافتراضية') {
            steps {
                sh '''
                    # إنشاء بيئة افتراضية
                    python3 -m venv venv
                    source venv/bin/activate
                    
                    # تحديث pip
                    pip install --upgrade pip
                    pip install wheel
                    
                    # تثبيت Django والمكتبات المطلوبة
                    pip install django djangorestframework django-cors-headers psycopg2-binary gunicorn
                    
                    # تثبيت أدوات الاختبار والجودة
                    pip install pytest pytest-django pytest-cov flake8 black
                    
                    # تثبيت أي متطلبات إضافية من ملف requirements.txt إذا وجد
                    if [ -f "requirements.txt" ]; then
                        pip install -r requirements.txt
                    fi
                    
                    # تثبيت متطلبات backend إذا كان هناك مجلد منفصل
                    if [ -f "backend/requirements.txt" ]; then
                        pip install -r backend/requirements.txt
                    fi
                '''
                echo '✅ تم تجهيز البيئة الافتراضية وتثبيت المكتبات'
            }
        }
        
        stage('🔍 فحص جودة الكود (Linting)') {
            steps {
                sh '''
                    source venv/bin/activate
                    
                    # فحص باستخدام flake8
                    echo "🔍 جاري فحص الكود..."
                    flake8 . --count --select=E9,F63,F7,F82 --show-source --statistics || true
                    
                    # فحص التنسيق باستخدام black
                    echo "🎨 جاري فحص التنسيق..."
                    black --check . --diff || echo "⚠️ تحتاج بعض الملفات إلى تنسيق"
                '''
                echo '✅ تم اجتياز فحص الجودة'
            }
        }
        
        stage('🗄️ إعداد قاعدة البيانات للاختبار') {
            steps {
                sh '''
                    # تشغيل PostgreSQL باستخدام Docker (من compose.yaml)
                    if command -v docker &> /dev/null; then
                        docker-compose -f compose.yaml up -d db
                        echo "⏳ انتظار تشغيل قاعدة البيانات..."
                        sleep 10
                    else
                        echo "⚠️ Docker غير مثبت، استخدام SQLite للاختبارات"
                        export DB_ENGINE='django.db.backends.sqlite3'
                        export DB_NAME='db.sqlite3'
                    fi
                '''
                echo '✅ قاعدة البيانات جاهزة'
            }
        }
        
        stage('🔄 تنفيذ ترحيلات قاعدة البيانات') {
            steps {
                sh '''
                    source venv/bin/activate
                    
                    # الانتقال إلى مجلد backend إذا كان المشروع منظماً هناك
                    if [ -d "backend" ]; then
                        cd backend
                    fi
                    
                    # إنشاء الترحيلات وتنفيذها
                    python manage.py makemigrations --noinput || true
                    python manage.py migrate --noinput
                    
                    # العودة إلى المجلد الرئيسي
                    cd ..
                '''
                echo '✅ تم تنفيذ الترحيلات بنجاح'
            }
        }
        
        stage('🧪 تشغيل الاختبارات') {
            steps {
                sh '''
                    source venv/bin/activate
                    
                    # تشغيل الاختبارات مع تغطية الكود
                    if [ -d "backend" ]; then
                        cd backend
                        python manage.py test --verbosity=2 --noinput
                        cd ..
                    else
                        python manage.py test --verbosity=2 --noinput
                    fi
                    
                    # أو استخدام pytest إذا كان مفضلاً
                    # pytest --cov=. --cov-report=xml --cov-report=term
                '''
                echo '✅ اجتازت جميع الاختبارات بنجاح'
            }
        }
        
        stage('🐳 بناء Docker Image') {
            when {
                branch 'main'
            }
            steps {
                script {
                    if (fileExists('compose.yaml') || fileExists('Dockerfile')) {
                        sh '''
                            # بناء الصورة باستخدام docker-compose
                            docker-compose -f compose.yaml build
                            
                            # وضع علامة (tag) على الصورة
                            docker tag crud-hr-app-web:latest bherradi/crud-hr-app:${BUILD_NUMBER}
                            docker tag crud-hr-app-web:latest bherradi/crud-hr-app:latest
                        '''
                        echo '✅ تم بناء صورة Docker بنجاح'
                    } else {
                        echo '⚠️ لا يوجد Dockerfile أو compose.yaml، تخطي مرحلة البناء'
                    }
                }
            }
        }
        
        stage('🚀 نشر إلى الخادم (اختياري)') {
            when {
                branch 'main'
            }
            steps {
                script {
                    // يمكنك إضافة خطوات النشر حسب احتياجاتك
                    // مثال: النشر إلى Docker Hub
                    // withCredentials([string(credentialsId: 'docker-hub-password', variable: 'DOCKER_PASS')]) {
                    //     sh '''
                    //         echo $DOCKER_PASS | docker login -u bherradi --password-stdin
                    //         docker push bherradi/crud-hr-app:latest
                    //     '''
                    // }
                    
                    // أو النشر إلى خادم عبر SSH
                    // sh '''
                    //     ssh user@your-server.com "cd /app && docker-compose pull && docker-compose up -d"
                    // '''
                    
                    echo '✅ تم النشر (تم تخطي النشر التلقائي - أضف إعداداتك هنا)'
                }
            }
        }
    }
    
    post {
        success {
            echo '🎉🎉🎉 Pipeline completed successfully! 🎉🎉🎉'
            // إرسال إشعار نجاح (اختياري)
            // emailext (
            //     subject: "✅ نجاح البناء: ${env.JOB_NAME} - ${env.BUILD_NUMBER}",
            //     body: "البناء رقم ${env.BUILD_NUMBER} اكتمل بنجاح!\nالرابط: ${env.BUILD_URL}",
            //     to: 'team@example.com'
            // )
        }
        failure {
            echo '❌❌❌ Pipeline failed! ❌❌❌'
            echo 'يرجى مراجعة السجلات أعلاه لمعرفة سبب الفشل'
            // إرسال إشعار فشل (اختياري)
            // emailext (
            //     subject: "❌ فشل البناء: ${env.JOB_NAME} - ${env.BUILD_NUMBER}",
            //     body: "فشل البناء رقم ${env.BUILD_NUMBER}\nالرابط: ${env.BUILD_URL}\nيرجى مراجعة الأخطاء.",
            //     to: 'team@example.com'
            // )
        }
        always {
            // تنظيف البيئة
            sh '''
                # إيقاف حاويات Docker
                if command -v docker &> /dev/null; then
                    docker-compose -f compose.yaml down 2>/dev/null || true
                fi
                
                # حذف البيئة الافتراضية
                rm -rf venv || true
            '''
            echo '🧹 تم التنظيف'
        }
    }
}